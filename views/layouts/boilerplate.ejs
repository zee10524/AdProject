<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MusafirKhana</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

    <style>
      #chat-widget * { box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
      #chat-btn {
        background: linear-gradient(135deg, #fe424d, #ff6b35);
        color: white; border: none; border-radius: 50px;
        padding: 13px 20px; cursor: pointer; font-size: 15px;
        font-weight: 600; box-shadow: 0 4px 20px rgba(254,66,77,0.4);
        display: flex; align-items: center; gap: 8px; transition: all 0.2s;
      }
      #chat-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(254,66,77,0.5); }
      #chat-box {
        width: 355px; height: 510px; background: white; border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.18); display: flex;
        flex-direction: column; margin-bottom: 12px; overflow: hidden;
        animation: slideUp 0.25s ease;
      }
      @keyframes slideUp {
        from { opacity:0; transform:translateY(20px); }
        to   { opacity:1; transform:translateY(0); }
      }
      #chat-header {
        background: linear-gradient(135deg, #fe424d, #ff6b35);
        color: white; padding: 14px 16px; display: flex;
        justify-content: space-between; align-items: center; flex-shrink: 0;
      }
      .bot-info { display: flex; align-items: center; gap: 10px; }
      .bot-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex; align-items: center; justify-content: center; font-size: 17px;
      }
      .bot-name { font-weight: 700; font-size: 15px; }
      .bot-status { font-size: 11px; opacity: 0.85; }
      #chat-close {
        background: rgba(255,255,255,0.2); border: none; color: white;
        width: 28px; height: 28px; border-radius: 50%; cursor: pointer;
        font-size: 15px; display: flex; align-items: center; justify-content: center;
      }
      #chat-close:hover { background: rgba(255,255,255,0.35); }
      #quick-questions {
        padding: 9px 10px 7px; display: flex; gap: 6px; flex-wrap: wrap;
        border-bottom: 1px solid #f0f0f0; flex-shrink: 0; background: #fafafa;
      }
      .quick-btn {
        background: white; border: 1.5px solid #fe424d; color: #fe424d;
        border-radius: 20px; padding: 5px 10px; font-size: 11.5px;
        font-weight: 600; cursor: pointer; transition: all 0.2s;
      }
      .quick-btn:hover { background: #fe424d; color: white; }
      #chat-messages {
        flex: 1; overflow-y: auto; padding: 12px 11px;
        display: flex; flex-direction: column; gap: 9px; scroll-behavior: smooth;
      }
      #chat-messages::-webkit-scrollbar { width: 4px; }
      #chat-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }
      .msg-bubble {
        max-width: 88%; padding: 10px 13px; border-radius: 14px;
        font-size: 13.5px; line-height: 1.55; word-break: break-word;
      }
      .msg-user {
        background: linear-gradient(135deg, #fe424d, #ff6b35);
        color: white; align-self: flex-end; border-bottom-right-radius: 4px;
      }
      .msg-bot {
        background: #f4f4f4; color: #222;
        align-self: flex-start; border-bottom-left-radius: 4px;
      }
      .msg-bot strong { font-weight: 700; color: #111; }
      .typing-dots { display: flex; gap: 5px; align-items: center; padding: 4px 0; }
      .typing-dots span {
        width: 7px; height: 7px; border-radius: 50%;
        background: #bbb; animation: bounce 1.2s infinite;
      }
      .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
      .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes bounce {
        0%,60%,100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
      }
      #chat-input-area {
        padding: 10px 11px; border-top: 1px solid #efefef;
        display: flex; gap: 8px; flex-shrink: 0; background: white;
      }
      #chat-input {
        flex: 1; padding: 9px 14px; border: 1.5px solid #e0e0e0;
        border-radius: 24px; font-size: 13px; outline: none;
        transition: border-color 0.2s; font-family: inherit;
      }
      #chat-input:focus { border-color: #fe424d; }
      #send-btn {
        width: 38px; height: 38px;
        background: linear-gradient(135deg, #fe424d, #ff6b35);
        color: white; border: none; border-radius: 50%;
        cursor: pointer; font-size: 15px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        transition: transform 0.15s;
      }
      #send-btn:hover { transform: scale(1.1); }
    </style>
</head>

<body>
    <%- include("../includes/navbar.ejs") %>
    <div class="container" style="width: 100% !important;">
        <%- include("../includes/flash.ejs") %>
        <%- body %>
    </div>
    <%- include("../includes/footer.ejs") %>

    <!-- MusaphirBot Chat Widget -->
    <div id="chat-widget" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;">

      <div id="chat-box" style="display:none;">
        <div id="chat-header">
          <div class="bot-info">
            <div class="bot-avatar">🧳</div>
            <div>
              <div class="bot-name">MusafirBot</div>
              <div class="bot-status">● Always here to help</div>
            </div>
          </div>
          <button id="chat-close" onclick="toggleChat()">✕</button>
        </div>

        <div id="quick-questions">
          <button class="quick-btn" onclick="askQuick('refund policy')">💰 Refund Policy</button>
          <button class="quick-btn" onclick="askQuick('how to book a stay')">🏨 How to Book</button>
          <button class="quick-btn" onclick="askQuick('check-in time')">🕑 Check-in Time</button>
          <button class="quick-btn" onclick="askQuick('available listings')">🔍 View Listings</button>
          <button class="quick-btn" onclick="askQuick('travel agent')">🧑‍💼 Travel Agent</button>
        </div>

        <div id="chat-messages">
          <div class="msg-bubble msg-bot">
            👋 Hi! I'm <strong>MusafirBot</strong>.<br><br>
            I can help with <strong>bookings, refunds, check-in, travel tips, payments</strong> and more!<br><br>
            Tap a quick question or type anything! 😊
          </div>
        </div>

        <div id="chat-input-area">
          <input id="chat-input" type="text" placeholder="Ask me anything about travel..."
            onkeypress="if(event.key==='Enter') sendMessage()" />
          <button id="send-btn" onclick="sendMessage()">➤</button>
        </div>
      </div>

      <button id="chat-btn" onclick="toggleChat()">💬 Ask MusafirBot</button>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>

    <script>
      let chatOpen = false;

      function toggleChat() {
        chatOpen = !chatOpen;
        document.getElementById("chat-box").style.display = chatOpen ? "flex" : "none";
        document.getElementById("chat-btn").style.display = chatOpen ? "none" : "flex";
        if (chatOpen) setTimeout(() => document.getElementById("chat-input").focus(), 100);
      }

      function askQuick(q) {
        document.getElementById("chat-input").value = q;
        sendMessage();
      }

      async function sendMessage() {
        const input = document.getElementById("chat-input");
        const msg = input.value.trim();
        if (!msg) return;
        addMsg("user", msg);
        input.value = "";
        const tid = "t" + Date.now();
        addTyping(tid);
        try {
          const res = await fetch("/api/chatbot/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ message: msg })
          });
          const data = await res.json();
          document.getElementById(tid)?.remove();
          addMsg("bot", data.reply || "Sorry, something went wrong. Please try again.");
        } catch (e) {
          document.getElementById(tid)?.remove();
          addMsg("bot", "⚠️ Unable to reach the server. Please refresh and try again.");
        }
      }

      function addMsg(role, html) {
        const box = document.getElementById("chat-messages");
        const d = document.createElement("div");
        d.className = "msg-bubble " + (role === "user" ? "msg-user" : "msg-bot");
        if (role === "bot") d.innerHTML = html;
        else d.textContent = html;
        box.appendChild(d);
        box.scrollTop = box.scrollHeight;
      }

      function addTyping(id) {
        const box = document.getElementById("chat-messages");
        const d = document.createElement("div");
        d.id = id;
        d.className = "msg-bubble msg-bot";
        d.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
        box.appendChild(d);
        box.scrollTop = box.scrollHeight;
      }
    </script>
</body>
</html>

